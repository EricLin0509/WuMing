<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="Adw" version="1.4"/>

  <template class="SecurityOverviewPage" parent="AdwBin">
    <property name="child">
      <object class="AdwStatusPage" id="status_page">
        <property name="child">
          <object class="AdwClamp" id="clamp">
            <property name="maximum-size">500</property>
            <property name="tightening-threshold">300</property>
            <property name="child">
              <object class="GtkListBox">
                <style>
                  <class name="boxed-list"/>
                </style>
                <child>
                  <object class="AdwActionRow" id="scan_overview_row">
                    <property name="title" translatable="yes">Last Scan Time</property>
                    <property name="activatable">True</property>
                    <property name="action-name">win.goto-scan-page</property>
                    <child type="prefix">
                      <object class="GtkImage" id="scan_overview_icon">
                        <property name="icon-name">status-ok-symbolic</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="AdwActionRow" id="signature_overview_row">
                    <property name="title" translatable="yes">Current Signature Status</property>
                    <property name="activatable">True</property>
                    <property name="action-name">win.update</property>
                    <child type="prefix">
                      <object class="GtkImage" id="signature_overview_icon">
                        <property name="icon-name">status-ok-symbolic</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="AdwActionRow" id="service_overview_row">
                    <property name="title" translatable="yes">Freshclam Service Status</property>
                    <property name="activatable">True</property>
                    <child type="prefix">
                      <object class="GtkImage" id="service_overview_icon">
                        <property name="icon-name">status-ok-symbolic</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </property>
          </object>
        </property>
      </object>
    </property>
  </template>
</interface>
